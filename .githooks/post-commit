#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

BINS=(bonfyre-media-prep bonfyre-transcribe bonfyre-transcript-clean bonfyre-paragraph bonfyre-brief bonfyre-clips bonfyre-tag bonfyre-narrate bonfyre-emit bonfyre-render bonfyre-pack)
require_bin "${BINS[@]}" || exit 0

CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD -- input/ 2>/dev/null || true)
[ -z "$CHANGED" ] && exit 0

log "Podcast Plant: processing $(echo "$CHANGED" | wc -l | tr -d ' ') episode(s)…"

for f in $CHANGED; do
  [ -f "$f" ] || continue
  base=$(basename "$f" | sed 's/\.[^.]*$//')
  ext="${f##*.}"

  case "$ext" in
    wav|mp3|m4a|ogg|flac|webm)
      log "[$base] Full repurposing pipeline (11 stages)"
      bonfyre-media-prep "$f" --out "artifacts/${base}.prep.json"
      bonfyre-transcribe "artifacts/${base}.prep.json" --out "artifacts/${base}.transcript.json"
      bonfyre-transcript-clean "artifacts/${base}.transcript.json" --out "artifacts/${base}.clean.json"
      bonfyre-paragraph "artifacts/${base}.clean.json" --out "artifacts/${base}.paragraphs.json"
      bonfyre-brief "artifacts/${base}.paragraphs.json" --out "artifacts/${base}.brief.json"
      bonfyre-clips "artifacts/${base}.transcript.json" --out "artifacts/${base}.clips.json"
      bonfyre-tag "artifacts/${base}.brief.json" --out "artifacts/${base}.tags.json"
      bonfyre-narrate "artifacts/${base}.brief.json" --out "artifacts/${base}.narrate.json"
      bonfyre-render "artifacts/${base}.narrate.json" --template episode --out "site/episodes/${base}.html"
      bonfyre-pack "artifacts/${base}.brief.json" --out "artifacts/${base}.pack.zip"
      ;;
    *) log "[$base] skipping: $ext" ;;
  esac
done

log "Rebuilding show site + RSS…"
bonfyre-emit artifacts/ --out site/ --format html
bonfyre-emit artifacts/ --out site/feed/ --format rss
log "Done. $(find site/episodes/ -name '*.html' | wc -l | tr -d ' ') episodes published."
